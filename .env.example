# Environment configuration template
#
# Copy this file to `.env` in the repository root and fill in only the keys you
# use. The real `.env` is ignored by Git. For compatibility with related internal
# projects, fetch scripts also check for `.env` one directory above the repository.

# CEIC Database Access (optional fetch-ceic skill)
# Ask your organization's CEIC administrator for authorized API access.
# Service information: https://info.ceicdata.com/api-and-data-feed-solution
CEIC_API_KEY=your_long_ceic_api_token_here

# Bank of Thailand API Access (optional fetch-bot skill)
# Register and subscribe to the required product at the current portal:
# https://portal.api.bot.or.th/
BOT_API_TOKEN=your_bot_api_token_here

# U.S. Energy Information Administration API v2 (optional fetch-eia skill)
# Register at https://www.eia.gov/opendata/register.php
EIA_API_KEY=your_40_character_eia_api_key_here

# IMF Developer API Access (optional fetch-imf skill)
# Sign in and subscribe through https://portal.api.imf.org/
IMF_API_KEY=your_32_character_imf_api_key_here

# S&P Global Connect Databrowser (optional fetch-sp skill)
# Obtain access from your organization's S&P Global API administrator.
# Auth is HTTP Basic: PAT as username, password as password.
SP_USERNAME=your_sp_username_here
SP_PASSWORD=your_sp_password_here

# fetch-moc and fetch-worldbank require no API key.
